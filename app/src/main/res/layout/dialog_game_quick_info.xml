<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/quickInfoRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvQuickGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reaction Time"
        android:textColor="#1C1C1C"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvQuickGameSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Test your reaction speed under pressure."
        android:textColor="#616161"
        android:textSize="14sp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvQuickWorldBest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:id="@+id/llQuickWorldBest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F6F1FF"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvQuickWorldBestLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Global Benchmark"
                android:textColor="#5D2ED7"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQuickWorldBestValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="95 ms avg"
                android:textColor="#2C2C2C"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvQuickYourBest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:id="@+id/llQuickYourBest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EEF7FF"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvQuickYourBestLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Best"
                android:textColor="#1565C0"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQuickYourBestValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="--"
                android:textColor="#2C2C2C"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvQuickGameTips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Tip: Keep your thumb close to the target area and avoid anticipation taps."
        android:textColor="#5F6368"
        android:textSize="13sp" />

</LinearLayout>
