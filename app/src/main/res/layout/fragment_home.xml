<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/svHomeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvProfileHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="7dp"
            android:layout_marginBottom="14dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/pvProfileBackground"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    app:use_controller="false" />

                <View
                    android:id="@+id/vProfileOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#66000000"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/llProfileContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F6F1FF"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                <ImageView
                    android:id="@+id/ivProfileAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:contentDescription="Profile image"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_myplaces" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atharva"
                        android:textColor="#1C1C1C"
                        android:textSize="19sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfileOverallScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Overall Score: 1250"
                        android:textColor="#5D2ED7"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <Button
                        android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#6200EE"
                        android:text="Edit"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Header -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome, User!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cognitive Games"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvBenchmark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap a game to select · Long-press for quick actions"
            android:textSize="13sp"
            android:textColor="#5F6368"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

        <!-- Game 1: Reaction Time (Blue) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvReactionTime"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginHorizontal="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#2979FF"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="⚡"
                        android:gravity="center"
                        android:textSize="20sp"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:id="@+id/tvGame1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reaction Time"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGame1Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VISUAL REFLEXES"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGame1Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST: 215ms"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Game 2: Sequence Memory (Green) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvSequenceMemory"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginHorizontal="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#00C853"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="&#9998;"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:id="@+id/tvGame2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sequence Memory"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGame2Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PATTERN RETENTION"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGame2Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST: Level 14"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Game 3: Verbal Memory (Orange) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvVerbalMemory"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginHorizontal="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FF6D00"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="A"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:id="@+id/tvGame3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verbal Memory"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGame3Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WORD RECOGNITION"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGame3Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST: 82 Words"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Game 4: Number Memory (Purple) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvNumberMemory"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginHorizontal="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#AA00FF"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="#"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:id="@+id/tvGame4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Number Memory"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGame4Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIGIT SPAN TEST"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGame4Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST: 12 Digits"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Game 5: Visual Memory (Teal) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvVisualMemory"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginHorizontal="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#00BFA5"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="&#9635;"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:id="@+id/tvGame5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visual Memory"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGame5Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3X3 GRID SQUARES"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGame5Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST: Level 11"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Game 6: Chimp Test (Dark Slate) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cvChimpTest"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginHorizontal="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#455A64"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="&#8801;"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">
                    <TextView
                        android:id="@+id/tvGame6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chimp Test"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvGame6Type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NUMBER SEQUENCING"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGame6Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST: 18 Numbers"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>