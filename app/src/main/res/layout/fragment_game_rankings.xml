<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Game Rankings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#6200EE"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Individual Games"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Game Filter Chips - Horizontally scrollable for 6 games -->
    <HorizontalScrollView
        android:id="@+id/chipContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvReactionChip"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Reaction"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="#E0E0E0"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvSequenceChip"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Sequence"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="#E0E0E0"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvVerbalChip"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Verbal"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="#E0E0E0"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvNumberChip"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Number"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="#E0E0E0"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvVisualChip"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Visual"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="#E0E0E0"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvChimpChip"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Chimp"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="#E0E0E0"/>

        </LinearLayout>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/chipContainer"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvApiStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginStart="8dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toEndOf="@id/pbLoading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chipContainer" />

    <!-- World Record Holder -->
    <TextView
        android:id="@+id/tvWorldRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆 WORLD RECORD HOLDER"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvApiStatus"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Rank 1 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvRank1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvWorldRecord"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRank1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFD700"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvName1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Alex Johnson"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvRank1"
                app:layout_constraintEnd_toStartOf="@id/tvScore1"/>

            <TextView
                android:id="@+id/tvScore1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="142ms"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#6200EE"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Rank 2 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvRank2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="2dp"
        app:cardCornerRadius="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/cvRank1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRank2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#C0C0C0"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvName2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Sarah Miller"
                android:textSize="16sp"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvRank2"
                app:layout_constraintEnd_toStartOf="@id/tvScore2"/>

            <TextView
                android:id="@+id/tvScore2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="158ms"
                android:textSize="16sp"
                android:textColor="#6200EE"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Rank 3 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvRank3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="2dp"
        app:cardCornerRadius="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/cvRank2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRank3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#CD7F32"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvName3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Chen Wei"
                android:textSize="16sp"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvRank3"
                app:layout_constraintEnd_toStartOf="@id/tvScore3"/>

            <TextView
                android:id="@+id/tvScore3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="164ms"
                android:textSize="16sp"
                android:textColor="#6200EE"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Current User -->
    <TextView
        android:id="@+id/tvYourRank"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YOUR RANKING"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#6200EE"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cvRank3"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvYourRank"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvYourRank"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clYourRankContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="#E8E8E8">

            <TextView
                android:id="@+id/tvYourRankNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#42"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#6200EE"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvYourName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="You (David)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvYourRankNumber"
                app:layout_constraintEnd_toStartOf="@id/tvYourScore"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tvYourScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="198ms"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#6200EE"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>