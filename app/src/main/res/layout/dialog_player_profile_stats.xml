<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/playerStatsRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/llPlayerStatsContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivDialogAvatar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_myplaces" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDialogPlayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player Name"
                    android:textColor="#1C1C1C"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDialogRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="#1 Global"
                    android:textColor="#5D2ED7"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvPlayerPoints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/llPlayerPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F6F1FF"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tvDialogPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="995 pts"
                    android:textColor="#5D2ED7"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDialogPercentile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="99.9TH PERCENTILE"
                    android:textColor="#6D6D6D"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvGamewiseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Game-wise Performance"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStatReaction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F4F5F7"
                android:padding="10dp"
                android:text="Reaction Time: 146 ms avg"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStatSequence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#F4F5F7"
                android:padding="10dp"
                android:text="Sequence Memory: Level 47"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStatVerbal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#F4F5F7"
                android:padding="10dp"
                android:text="Verbal Memory: 82 Words"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStatNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#F4F5F7"
                android:padding="10dp"
                android:text="Number Memory: Level 17"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStatVisual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#F4F5F7"
                android:padding="10dp"
                android:text="Visual Memory: Level 16"
                android:textColor="#333333"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStatChimp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="#F4F5F7"
                android:padding="10dp"
                android:text="Chimp Test: Score 26"
                android:textColor="#333333"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
