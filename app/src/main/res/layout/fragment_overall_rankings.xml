<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overall Rankings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#6200EE"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- User Standing Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvUserStanding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="8dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvYourStanding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR STANDING"
                android:textSize="14sp"
                android:textColor="#757575"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvYourRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#1,240"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#6200EE"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvYourStanding"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvYourPercentile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top 4.2% Global"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvYourRank"
                app:layout_constraintStart_toStartOf="parent"/>

            <Button
                android:id="@+id/btnViewStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Stats"
                android:backgroundTint="#03DAC5"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <Button
                android:id="@+id/btnShare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share"
                android:backgroundTint="#6200EE"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnViewStats"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Global Top 100 Header -->
    <TextView
        android:id="@+id/tvGlobalHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Global Top 100"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cvUserStanding"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvAllTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All Time"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/tvGlobalHeader"
        app:layout_constraintBottom_toBottomOf="@id/tvGlobalHeader"
        app:layout_constraintStart_toEndOf="@id/tvGlobalHeader"/>

    <EditText
        android:id="@+id/etPlayerSearch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/edit_text"
        android:hint="Search players"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvGlobalHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSearchHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Tap a player row to view game-wise scores"
        android:textColor="#757575"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/etPlayerSearch"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Table Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tableHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:background="#F0F0F0"
        app:layout_constraintTop_toBottomOf="@id/tvSearchHint">

        <TextView
            android:id="@+id/tvHeaderRank"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rank"
            android:textStyle="bold"
            android:textColor="#757575"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvHeaderName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"
            android:textColor="#757575"
            android:layout_marginStart="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvHeaderRank"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvHeaderPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Points"
            android:textStyle="bold"
            android:textColor="#757575"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Rank 1 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rank1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tableHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvRank1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvName1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Alex Rivera"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvRank1"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvPoints1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="995 pts"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#6200EE"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvPercentile1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="99.9TH PERCENTILE"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvName1"
            app:layout_constraintStart_toStartOf="@id/tvName1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Rank 2 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rank2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/rank1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvRank2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#C0C0C0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvName2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Sam Chen"
            android:textSize="16sp"
            android:layout_marginStart="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvRank2"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvPoints2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="988 pts"
            android:textSize="16sp"
            android:textColor="#6200EE"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvPercentile2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="99.8TH PERCENTILE"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvName2"
            app:layout_constraintStart_toStartOf="@id/tvName2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Rank 3 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rank3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/rank2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvRank3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#CD7F32"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvName3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Jordan Taylor"
            android:textSize="16sp"
            android:layout_marginStart="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvRank3"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvPoints3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="982 pts"
            android:textSize="16sp"
            android:textColor="#6200EE"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tvPercentile3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="99.7TH PERCENTILE"
            android:textSize="12sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvName3"
            app:layout_constraintStart_toStartOf="@id/tvName3"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvNoSearchResults"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="No players found"
        android:textColor="#757575"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/rank3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>